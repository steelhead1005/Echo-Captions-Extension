{
  "manifest_version": 3,
  "name": "Echo360 Fullscreen Captions",
  "version": "1.1",
  "description": "Mirrors the Echo360 active transcript directly over the video player.",
  "browser_specific_settings": {
    "gecko": {
      "id": "echo360-captions@yourname.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Caption Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "*://echo360.net.au/*",
        "*://*.echo360.net.au/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}